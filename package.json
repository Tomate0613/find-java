{
  "name": "@doublekekse/find-java",
  "version": "1.0.0",
  "description": "A utility to find or download java",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit --composite false",
    "build": "pnpm build:esm && pnpm build:cjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "prepare": "pnpm build",
    "script": "node scripts/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doublekekse/find-java.git"
  },
  "keywords": [
    "java",
    "utility"
  ],
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/node-fetch": "^2.6.13",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "tsup": "^8.5.1"
  },
  "license": "MIT"
}
